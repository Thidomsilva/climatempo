# .env.example — Copie para .env e preencha

# ── Obrigatório ─────────────────────────────────────────────
# Token do seu bot no Telegram (obtenha com @BotFather)
TELEGRAM_TOKEN=seu_token_aqui

# Chave de criptografia para as private keys dos usuários
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPT_KEY=sua_chave_fernet_aqui

# Diretório local para armazenar o SQLite criptografado (não versionar no Git)
APP_DATA_DIR=.secure_data

# ── Opcional ─────────────────────────────────────────────────
# Intervalo do scanner em segundos (padrão: 300 = 5 minutos)
SCAN_INTERVAL=300

# Edge mínimo padrão para novos usuários (padrão: 0.15 = 15%)
DEFAULT_MIN_EDGE=0.15

# Tamanho padrão por trade em USDC (padrão: 10)
DEFAULT_TRADE_SIZE=10.0
